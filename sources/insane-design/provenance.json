{
  "schema": 1,
  "id": "insane-design",
  "display_name": "insane-design (gptaku-plugins)",
  "source_type": "installed-plugin",
  "absorbed_at": "2026-06-30",
  "locator": {
    "plugin_key": "insane-design@gptaku-plugins",
    "plugin_path": "gptaku-plugins/plugins/insane-design",
    "manifest_path": "gptaku-plugins/plugins/insane-design/.claude-plugin/plugin.json"
  },
  "absorbed_version": {
    "plugin_version": "0.5.3",
    "contract": {
      "report_path_glob": "docs/reports/<slug>/design.md",
      "frontmatter_schema_version": "3.2",
      "frontmatter_keys": ["schema_version", "colors", "typography", "radius", "spacing"]
    }
  },
  "dependents": [
    {
      "asset": "patches/design-discovery/skill/design-discovery/SKILL.md",
      "depends_on": [
        "insane-design 사전분석 리포트 경로 layout docs/reports/<slug>/design.md",
        "리포트 design.md frontmatter schema_version + 토큰 키(colors/typography/radius/spacing)",
        "insane-build 스킬의 HTML+CSS 출력 계약(P4 목업)"
      ],
      "break_if": [
        "리포트 경로/slug layout 이동",
        "schema_version MAJOR bump으로 토큰 블록 재구성",
        "토큰 키 rename/삭제",
        "insane-build 출력 계약 변경"
      ]
    }
  ],
  "drift_probe": {
    "kind": "manifest_version + artifact_schema (declared x sample cross-validate)",
    "schema_probe": { "file_glob": "docs/reports/*/design.md", "field": "schema_version" },
    "declared_probe": { "file_glob": "skills/insane-design/references/schema.v*.md", "version_regex": "v([0-9]+(?:\\.[0-9]+)*)" }
  }
}
